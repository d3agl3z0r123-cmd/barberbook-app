{
    "name": "barberpro/backend",
    "type": "project",
    "description": "Backend Laravel multi-tenant para gestao de barbearias.",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "endroid/qr-code": "^6.0",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.26",
        "laravel/tinker": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.4",
        "laravel/pint": "^1.20",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan package:discover --ansi"
        ],
        "test": [
            "@php artisan test"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
